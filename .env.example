# DATABASE_URL dipakai aplikasi runtime dan seed.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# DIRECT_URL dipakai Prisma CLI untuk migrate deploy/status.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# NODE_ENV biasanya diatur oleh Next.js, npm script, atau process manager.
# Untuk VPS production, set NODE_ENV=production di process manager.
# NODE_ENV="development"

# NEXTAUTH_SECRET dipakai untuk menandatangani session.
NEXTAUTH_SECRET="ganti-dengan-hasil-openssl-rand-base64-32"

# NEXTAUTH_URL harus sama dengan origin aplikasi.
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth dipakai untuk login developer secara mandiri.
GITHUB_ID="isi-dengan-client-id-oauth-app"
GITHUB_SECRET="isi-dengan-client-secret-oauth-app"

# Password ini hanya dibutuhkan saat menjalankan seed baseline.
SEED_DEFAULT_PASSWORD="ChangeMe123!"

# SHADOW_DATABASE_URL hanya dibutuhkan saat membuat migration baru dengan prisma migrate dev
# di database yang membutuhkan shadow database terpisah.
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/internal_task_management_shadow?sslmode=require"

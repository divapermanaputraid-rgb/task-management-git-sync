# NEXTAUTH_SECRET dipakai untuk menandatangani session.
NEXTAUTH_SECRET="ganti-dengan-hasil-openssl-rand-base64-32"

# NEXTAUTH_URL harus sama dengan URL app lokal.
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth dipakai untuk login developer secara mandiri.
GITHUB_ID="isi-dengan-client-id-oauth-app"
GITHUB_SECRET="isi-dengan-client-secret-oauth-app"

# Password ini dipakai untuk semua akun seed baseline.
SEED_DEFAULT_PASSWORD="ChangeMe123!"


# SHADOW_DATABASE_URL hanya dibutuhkan jika nanti kamu author migration baru dengan prisma migrate dev
# di database yang memang menyediakan shadow database terpisah.
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/internal_task_management_shadow?schema=public"
